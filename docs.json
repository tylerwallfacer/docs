{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Vaults.fyi",
  "colors": {
    "primary": "#18abff",
    "light": "#96caff",
    "dark": "#187ee8"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Get API Access",
      "href": "https://vaultsfyi.fillout.com/t/tLA9t6HyAFus"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "introduction",
              "use-cases/for-wallets-and-apps",
              "use-cases/for-analysts",
              "use-cases/for-protocols"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/market-data",
              "concepts/transactions",
              "concepts/portfolio",
              "concepts/supported-protocols"
            ]
          },
          {
            "group": "Methodology",
            "pages": [
              "methodology/calculating-apy",
              "methodology/benchmark-rates",
              "methodology/reputation-scores",
              "methodology/indexing-onchain-data"
            ]
          },
          {
            "group": "SDK",
            "pages": [
              "sdk/quickstart",
              "sdk/reference",
              "sdk/tutorials/wallet-integration",
              "sdk/tutorials/data-analytics"
            ]
          },
          {
            "group": "AI & Agents",
            "pages": [
              "ai-agents/overview",
              "ai-agents/mcp-claude-desktop",
              "ai-agents/x402"
            ]
          },
          {
            "group": "Plans & Billing",
            "pages": [
              "plans/overview",
              "plans/credits"
            ]
          },
          {
            "group": "Resources",
            "pages": [
              "resources/faq",
              "resources/changelog",
              {
                "group": "Case Studies",
                "pages": [
                  "resources/case-studies",
                  "resources/case-studies/jumper-earn",
                  "resources/case-studies/kraken-wallet",
                  "resources/case-studies/gauntlet",
                  "resources/case-studies/maple-finance",
                  "resources/case-studies/nashpoint",
                  "resources/case-studies/etherscan"
                ]
              }
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "https://api.vaults.fyi/v2/documentation/json",
        "pages": [
          "api-reference/overview",
          {
            "group": "Sections",
            "pages": [
              "api-reference/general",
              "api-reference/detailed-vaults",
              "api-reference/historical",
              "api-reference/benchmarks",
              "api-reference/portfolio",
              "api-reference/transactions",
              "api-reference/nrt"
            ]
          },
          {
            "group": "Endpoints",
            "openapi": "https://api.vaults.fyi/v2/documentation/json"
          },
          {
            "group": "Legacy v1",
            "hidden": true,
            "pages": [
              "api/legacy/overview",
              "api/legacy/market-data",
              "api/legacy/position-tracking",
              "api/legacy/generate-payloads",
              "api/legacy/contextual-insights"
            ]
          }
        ]
      }
    ]
  },
  "fonts": {
    "family": "Geist"
  },
  "logo": {
    "light": "/images/Logo-384px-black.png",
    "dark": "/images/Logo-384px-white.png"
  },
  "appearance": {
    "default": "system"
  },
  "favicon": "/images/icon_blue.png",
  "background": {
    "color": {
      "light": "#FFFFFF"
    }
  },
  "redirects": [
    { "source": "/api/vaults.fyi-api-overview", "destination": "/api-reference/overview" },
    { "source": "/api/vaults.fyi-api-overview/insights-api", "destination": "/api-reference/overview" },
    { "source": "/general/faq", "destination": "/resources/faq" },
    { "source": "/general/methodology", "destination": "/methodology/calculating-apy" },
    { "source": "/api/general", "destination": "/api-reference/general" },
    { "source": "/api/detailed-vaults", "destination": "/api-reference/detailed-vaults" },
    { "source": "/api/historical", "destination": "/api-reference/historical" },
    { "source": "/api/benchmarks", "destination": "/api-reference/benchmarks" },
    { "source": "/api/portfolio", "destination": "/api-reference/portfolio" },
    { "source": "/api/transactions", "destination": "/api-reference/transactions" }
  ]
}
