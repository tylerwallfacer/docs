  "keyFeatures": [
    "Market data for 1,000+ DeFi vaults across 80+ protocols and 20+ chains",
    "Non-custodial transaction preparation for deposit, redeem, and claim actions",
    "Portfolio intelligence with idle asset detection and personalized yield recommendations",
    "Hourly on-chain indexing with proprietary reputation scores",
    "TypeScript and Python SDKs with full type safety",
    "AI/agent-ready with MCP server support and x402 pay-per-request access",
    "Benchmark rates (USD & ETH) for cross-network yield comparison",
    "Built-in monetization with fee schemes for integrators"
  ],
  "publicApiSurface": [
    "GET /v2/detailed-vaults",
    "GET /v2/detailed-vaults/{network}/{address}",
    "GET /v2/historical/{network}/{vaultAddress}",
    "GET /v2/benchmarks/{network}",
    "GET /v2/portfolio/positions/{userAddress}",
    "GET /v2/portfolio/best-deposit-options/{userAddress}",
    "GET /v2/portfolio/idle-assets/{userAddress}",
    "GET /v2/transactions/context/{userAddress}/{network}/{vaultAddress}",
    "GET /v2/transactions/{action}/{userAddress}/{network}/{vaultAddress}",
    "GET /v2/transactions/rewards/claim/{userAddress}",
    "GET /v2/networks",
    "GET /v2/assets",
    "GET /v2/protocols",
    "GET /v2/curators",
